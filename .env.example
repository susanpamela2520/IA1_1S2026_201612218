# HandTalk AI — Variables de entorno
# Copia este archivo como .env y llena los valores

# Token del Bot de Telegram (obtenido de @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# Chat ID del grupo o usuario al que se enviarán los mensajes
# Para grupos: -1001234567890
# Para usuarios: 123456789  (usar @userinfobot para obtenerlo)
TELEGRAM_CHAT_ID=-1001234567890
